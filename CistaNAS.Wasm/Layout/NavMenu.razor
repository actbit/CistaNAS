@using CistaNAS.Wasm.Auth
@using CistaNAS.Wasm.Services
@implements IDisposable
@inject WasmAuthStateProvider Auth
@inject AuthApiClient AuthApi
@inject IJSRuntime JS

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">CistaNAS</a>
        @if (Auth.IsLoggedIn)
        {
            <button class="btn btn-outline-light btn-sm" @onclick="HandleLogout">ログアウト</button>
        }
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" @onclick="CloseNavOnClick">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        @if (!_hasUsers)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="setup">
                    <span class="bi bi-gear-fill" aria-hidden="true"></span> 初期設定
                </NavLink>
            </div>
        }
        else if (Auth.IsLoggedIn)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="volumes">
                    <span class="bi bi-hdd-fill" aria-hidden="true"></span> ボリューム
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="settings">
                    <span class="bi bi-gear-fill" aria-hidden="true"></span> 設定
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="invite">
                    <span class="bi bi-envelope-fill" aria-hidden="true"></span> 招待
                </NavLink>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login">
                    <span class="bi bi-box-arrow-in-right" aria-hidden="true"></span> ログイン
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    private bool _hasUsers = true;

    protected override async Task OnInitializedAsync()
    {
        Auth.StateChanged += OnAuthStateChanged;
        try { _hasUsers = await AuthApi.HasAnyUsersAsync(); } catch { }
    }

    private async Task HandleLogout()
    {
        await Auth.LogoutAsync();
    }

    /// <summary>メニュー操作後にモバイル navbar を閉じる（インライン onclick を排除するため外部 JS へ移行）。</summary>
    private async Task CloseNavOnClick()
    {
        try { await JS.InvokeVoidAsync("cista.closeNavbar"); }
        catch { /* JS 未初期化時は無視 */ }
    }

    private void OnAuthStateChanged() => StateHasChanged();

    public void Dispose() => Auth.StateChanged -= OnAuthStateChanged;
}
