@page "/setup"
@using CistaNAS.Wasm.Services
@inject AuthApiClient AuthApi
@inject VolumeApiClient VolumeApi
@inject NavigationManager Nav

<PageTitle>初回セットアップ - CistaNAS</PageTitle>

@if (_hasUsers)
{
    <p>既にセットアップ済みです。</p>
    <a href="/login" class="btn btn-primary">ログイン画面へ</a>
}
else
{
    <div class="container form-narrow setup-center">
        <div class="card">
            <div class="card-header"><h3 class="mb-0">CistaNAS 初回セットアップ</h3></div>
            <div class="card-body">
                <p>管理者アカウントを作成してください。</p>

                @if (_error is not null)
                {
                    <div class="alert alert-danger">@_error</div>
                }

                <EditForm Model="_model" OnValidSubmit="HandleSetup" FormName="SetupForm">
                    <div class="mb-3">
                        <label class="form-label">ユーザー名</label>
                        <InputText @bind-Value="_model.Username" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">パスワード</label>
                        <InputText type="password" @bind-Value="_model.Password" class="form-control" />
                        <div class="form-text">12文字以上、小文字と数字を含めてください。</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">パスワード（確認）</label>
                        <InputText type="password" @bind-Value="_model.ConfirmPassword" class="form-control" />
                    </div>
                    <hr />
                    <div class="mb-3 form-check">
                        <InputCheckbox @bind-Value="_model.CreateVolume" class="form-check-input" id="chkVol" />
                        <label class="form-check-label" for="chkVol">最初のボリュームも作成する</label>
                    </div>
                    @if (_model.CreateVolume)
                    {
                        <div class="mb-3">
                            <label class="form-label">ボリューム名</label>
                            <InputText @bind-Value="_model.VolumeName" class="form-control" />
                        </div>
                    }
                    <button type="submit" class="btn btn-primary w-100" disabled="@_loading">セットアップ完了</button>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private bool _hasUsers = true; // 初期値 true（ロード中はセットアップ済みと表示）
    private SetupModel _model = new();
    private string? _error;
    private bool _loading;

    private sealed class SetupModel
    {
        public string Username { get; set; } = "admin";
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
        public bool CreateVolume { get; set; } = true;
        public string VolumeName { get; set; } = "data";
    }

    protected override async Task OnInitializedAsync()
    {
        _hasUsers = await AuthApi.HasAnyUsersAsync();
    }

    private async Task HandleSetup()
    {
        if (_loading) return;
        _loading = true;
        _error = null;

        try
        {
            if (_model.Password != _model.ConfirmPassword)
            {
                _error = "パスワードが一致しません。";
                return;
            }
            if (string.IsNullOrWhiteSpace(_model.Username) || string.IsNullOrWhiteSpace(_model.Password))
            {
                _error = "ユーザー名とパスワードは必須です。";
                return;
            }

            var ok = await AuthApi.SetupAsync(_model.Username, _model.Password);
            if (!ok)
            {
                _error = "既にセットアップ済みです。";
                return;
            }

            if (_model.CreateVolume && !string.IsNullOrWhiteSpace(_model.VolumeName))
            {
                try
                {
                    await VolumeApi.CreateAsync(_model.VolumeName, _model.Username, _model.Password, encrypted: true);
                }
                catch
                {
                    // ボリューム作成失敗は警告のみ
                }
            }

            Nav.NavigateTo("/login", forceLoad: false);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
