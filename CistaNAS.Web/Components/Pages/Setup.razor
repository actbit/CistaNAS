@page "/setup"
@using CistaNAS.Web.Services
@inject AccountService AccountSvc
@inject VolumeService VolumeSvc
@inject NavigationManager Nav

<PageTitle>初回セットアップ - CistaNAS</PageTitle>

@if (_hasAnyUsers)
{
    <NavigateToLogin />
}
else
{
    <div class="container" style="max-width:500px; margin-top:80px">
        <div class="card">
            <div class="card-header"><h3 class="mb-0">CistaNAS 初回セットアップ</h3></div>
            <div class="card-body">
                <p>管理者アカウントを作成してください。</p>

                @if (_error is not null)
                {
                    <div class="alert alert-danger">@_error</div>
                }

                <EditForm Model="_model" OnValidSubmit="HandleSetup" FormName="SetupForm">
                    <div class="mb-3">
                        <label class="form-label">ユーザー名</label>
                        <InputText @bind-Value="_model.Username" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">パスワード</label>
                        <InputText type="password" @bind-Value="_model.Password" class="form-control" />
                        <div class="form-text">12文字以上、小文字と数字を含める必要があります。</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">パスワード（確認）</label>
                        <InputText type="password" @bind-Value="_model.ConfirmPassword" class="form-control" />
                    </div>
                    <hr />
                    <div class="mb-3 form-check">
                        <InputCheckbox @bind-Value="_model.CreateVolume" class="form-check-input" id="chkCreateVol" />
                        <label class="form-check-label" for="chkCreateVol">最初のボリュームも作成する</label>
                    </div>
                    @if (_model.CreateVolume)
                    {
                        <div class="mb-3">
                            <label class="form-label">ボリューム名</label>
                            <InputText @bind-Value="_model.VolumeName" class="form-control" />
                        </div>
                    }
                    <button type="submit" class="btn btn-primary w-100" disabled="@(_isSubmitting)">セットアップ完了</button>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private bool _hasAnyUsers;
    private SetupModel _model = new();
    private string? _error;
    private bool _isSubmitting;

    private sealed class SetupModel
    {
        public string Username { get; set; } = "admin";
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
        public bool CreateVolume { get; set; } = true;
        public string VolumeName { get; set; } = "data";
    }

    protected override async Task OnInitializedAsync()
    {
        _hasAnyUsers = await AccountSvc.HasAnyUsersAsync();
    }

    private async Task HandleSetup()
    {
        if (_isSubmitting) return;
        _isSubmitting = true;
        try
        {
            if (_model.Password != _model.ConfirmPassword)
            {
                _error = "パスワードが一致しません。";
                return;
            }
            if (string.IsNullOrWhiteSpace(_model.Username) || string.IsNullOrWhiteSpace(_model.Password))
            {
                _error = "ユーザー名とパスワードは必須です。";
                return;
            }

            if (_model.Password.Length < 12)
            {
                _error = "パスワードは12文字以上必要です。";
                return;
            }
            if (!_model.Password.Any(char.IsLower))
            {
                _error = "パスワードには小文字を含める必要があります。";
                return;
            }
            if (!_model.Password.Any(char.IsDigit))
            {
                _error = "パスワードには数字を含める必要があります。";
                return;
            }

            await AccountSvc.CreateInitialAdminAsync(_model.Username, _model.Password);

            if (_model.CreateVolume && !string.IsNullOrWhiteSpace(_model.VolumeName))
            {
                await VolumeSvc.CreateAsync(_model.VolumeName, _model.Username, _model.Password, encrypted: true);
                await VolumeSvc.LockAsync(_model.VolumeName, _model.Username);
            }

            Nav.NavigateTo("/login", forceLoad: false);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
