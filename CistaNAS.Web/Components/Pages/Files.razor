@page "/files/{VolumeName}"
@implements IAsyncDisposable
@implements IDisposable
@using CistaNAS.Web.Components.Auth
@using CistaNAS.Web.Models
@using CistaNAS.Web.Services
@using CistaNAS.Web.Volume
@using CistaNAS.Web.Helpers
@using Microsoft.JSInterop
@inject AuthenticationStateService AuthState
@inject VolumeService VolumeSvc
@inject FileService FileSvc
@inject E2eeFileService E2eeFileSvc
@inject E2eeInterop E2ee
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject StreamingTokenService StreamingTokenSvc

<PageTitle>ファイル: @VolumeName - CistaNAS</PageTitle>

@if (!AuthState.IsLoggedIn)
{
    <NavigateToLogin />
}
else if (!VolumeSvc.IsMounted(VolumeName))
{
    <div class="alert alert-warning">
        ボリューム「@VolumeName」はマウントされていません。
        <a href="/volumes">ボリューム管理に戻る</a>
    </div>
}
else if (!_hasAccess)
{
    <div class="alert alert-danger">
        ボリューム「@VolumeName」へのアクセス権がありません。
        <a href="/volumes">ボリューム管理に戻る</a>
    </div>
}
else if (_isE2ee && !_e2eeUnlocked)
{
    <h1>ファイル: @VolumeName</h1>
    <a href="/volumes" class="btn btn-outline-secondary mb-3">ボリューム一覧に戻る</a>

    <div class="card">
        <div class="card-header">E2EE ボリューム — パスワード入力</div>
        <div class="card-body">
            <div class="alert alert-info">
                このボリュームはエンドツーエンド暗号化されています。
                パスワードを入力してマスターキーを導出してください。
            </div>
            <div class="mb-3">
                <label class="form-label">パスワード</label>
                <input type="password" class="form-control" @bind="_e2eePassword" />
            </div>
            @if (_e2eeError is not null)
            {
                <div class="alert alert-danger">@_e2eeError</div>
            }
            <button class="btn btn-primary" disabled="@_e2eeUnlocking" @onclick="HandleE2eeUnlock">
                @(_e2eeUnlocking ? "導出中..." : "ロック解除")
            </button>
        </div>
    </div>
}
else
{
    <h1>ファイル: @VolumeName</h1>
    <a href="/volumes" class="btn btn-outline-secondary mb-3">ボリューム一覧に戻る</a>

    @if (_isE2ee)
    {
        <div class="alert alert-success mb-3">
            E2EE ボリューム — クライアント側暗号化有効
        </div>
    }

    <!-- アップロード -->
    <div class="card mb-4">
        <div class="card-header">ファイルアップロード</div>
        <div class="card-body">
            <InputFile OnChange="HandleUpload" accept="*/*" />
            @if (_uploadError is not null)
            {
                <div class="alert alert-danger mt-2">@_uploadError</div>
            }
            @if (_operationError is not null)
            {
                <div class="alert alert-danger mt-2">@_operationError</div>
            }
        </div>
    </div>

    <!-- ファイル一覧 -->
    @if (_isE2ee)
    {
        <h2>E2EE ファイル一覧</h2>
        @if (_e2eeFiles.Count == 0)
        {
            <p>ファイルがありません。</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>ファイル名</th>
                            <th class="d-none d-md-table-cell">チャンク数</th>
                            <th class="text-nowrap">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var f in _e2eeFiles)
                        {
                            <tr>
                                <td>@f.PlainName</td>
                                <td class="d-none d-md-table-cell">@f.Entry.ChunkCount</td>
                                <td>
                                    @if (MediaHelper.IsMedia(f.PlainName))
                                    {
                                        <button class="btn btn-sm btn-outline-success me-1"
                                                disabled="@f.Downloading"
                                                @onclick="() => HandleE2eePreview(f)">
                                            @(f.Downloading ? "読み込み中..." : "プレビュー")
                                        </button>
                                    }
                                    <button class="btn btn-sm btn-outline-primary me-1"
                                            disabled="@f.Downloading"
                                            @onclick="() => HandleE2eeDownload(f)">
                                        @(f.Downloading ? "ダウンロード中..." : "ダウンロード")
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => HandleE2eeDelete(f.Entry.FileId)">
                                        削除
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
    else
    {
        <h2>ファイル一覧</h2>
        @if (_files.Count == 0)
        {
            <p>ファイルがありません。</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>ファイル名</th>
                            <th class="d-none d-md-table-cell">サイズ</th>
                            <th class="d-none d-lg-table-cell">更新日時</th>
                            <th class="text-nowrap">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var f in _files)
                        {
                            <tr>
                                <td>@f.Name</td>
                                <td class="d-none d-md-table-cell">@FormatSize(f.Length)</td>
                                <td class="d-none d-lg-table-cell">@f.ModifiedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>
                                    @if (MediaHelper.IsMedia(f.Name))
                                    {
                                        <button class="btn btn-sm btn-outline-success me-1"
                                                @onclick="() => HandlePreview(f.Name)">
                                            プレビュー
                                        </button>
                                    }
                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => HandleDownload(f.Name)">ダウンロード</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => HandleDelete(f.Name)">削除</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
    }

<!-- メディアプレビューモーダル -->
@if (_previewVisible)
{
    <MediaPreview @ref="_previewRef"
                  FileName="@_previewFileName"
                  Type="_previewType"
                  StreamUrl="@_previewStreamUrl"
                  OnClose="ClosePreview" />
}

@code {
    [Parameter] public string VolumeName { get; set; } = "";

    // 通常ボリューム
    private List<FileMetadata> _files = [];
    private string? _uploadError;
    private string? _operationError;

    // E2EE 状態
    private bool _isE2ee;
    private bool _e2eeUnlocked;
    private bool _e2eeUnlocking;
    private string _e2eePassword = "";
    private string? _e2eeError;
    private string? _masterKeyHandle;
    private List<E2eeFileViewItem> _e2eeFiles = [];

    // メディアプレビュー
    private bool _previewVisible;
    private string _previewFileName = "";
    private MediaHelper.MediaType _previewType;
    private string? _previewStreamUrl;
    private MediaPreview? _previewRef;

    // アクセス権限
    private bool _hasAccess;

    private string CurrentUsername => AuthState.User?.Identity?.Name ?? "";

    protected override async Task OnInitializedAsync()
    {
        AuthState.Subscribe(OnAuthStateChanged);
        _isE2ee = GetVolumeEncryptionMode() == "e2ee";

        // ボリュームへのアクセス権を確認
        if (!string.IsNullOrEmpty(CurrentUsername) && VolumeSvc.IsMounted(VolumeName))
        {
            _hasAccess = await VolumeSvc.HasAccessAsync(VolumeName, CurrentUsername);
        }

        if (!_isE2ee)
        {
            await RefreshList();
        }
    }

    private string GetVolumeEncryptionMode()
    {
        try
        {
            var (_, header) = VolumeSvc.GetMounted(VolumeName);
            return header.EncryptionMode;
        }
        catch { return "server"; }
    }

    private async Task RefreshList()
    {
        try { _files = (await FileSvc.ListAsync(VolumeName)).Files.ToList(); }
        catch { _files = []; }
    }

    // ---- メディアプレビュー: 通常ボリューム ----

    /// <summary>
    /// 短命トークンを発行し、ストリーミングURLを生成して video/audio/img の src にセット。
    /// Range リクエスト対応のネイティブストリーミング。
    /// </summary>
    private async Task HandlePreview(string fileName)
    {
        var mediaType = MediaHelper.GetMediaType(fileName);
        if (mediaType == MediaHelper.MediaType.None) return;

        await RevokePreviewBlobUrl();

        _previewFileName = fileName;
        _previewType = mediaType;
        _previewStreamUrl = null;
        _previewVisible = true;

        try
        {
            var baseUri = Nav.BaseUri.TrimEnd('/');
            var streamToken = StreamingTokenSvc.Issue(CurrentUsername, VolumeName, fileName);
            _previewStreamUrl = $"{baseUri}/api/v1/stream/{Uri.EscapeDataString(VolumeName)}/{Uri.EscapeDataString(fileName)}?token={streamToken}";
        }
        catch (Exception ex)
        {
            _operationError = $"プレビューエラー: {ex.Message}";
            _previewVisible = false;
        }
    }

    // ---- メディアプレビュー: E2EE ボリューム ----

    /// <summary>
    /// E2EE メディアプレビュー。動画/音声は MSE ストリーミング、画像は Blob フォールバック。
    /// </summary>
    private async Task HandleE2eePreview(E2eeFileViewItem item)
    {
        var mediaType = MediaHelper.GetMediaType(item.PlainName);
        if (mediaType == MediaHelper.MediaType.None) return;

        await RevokePreviewBlobUrl();

        item.Downloading = true;
        _previewFileName = item.PlainName;
        _previewType = mediaType;
        _previewStreamUrl = null;
        _previewVisible = true;

        var entry = item.Entry;
        var mimeType = MediaHelper.GetMimeType(item.PlainName) ?? "application/octet-stream";

        // 画像は Blob 方式（サイズが小さいためストリーミング不要）
        if (mediaType == MediaHelper.MediaType.Image)
        {
            await HandleE2eePreviewBlob(item, entry, mimeType);
            item.Downloading = false;
            return;
        }

        // 動画/音声: MSE ストリーミング
        _previewRef?.SetE2eeLoading(entry.ChunkCount);

        // salt を先頭チャンクから取得
        string fileSaltB64;
        try
        {
            var (chunkStream, chunkLen) = await E2eeFileSvc.DownloadChunkAsync(VolumeName, entry.FileId, 0);
            byte[] firstChunk = new byte[chunkLen];
            using (chunkStream)
            {
                int read = 0;
                while (read < chunkLen)
                {
                    int n = await chunkStream.ReadAsync(firstChunk, read, (int)chunkLen - read);
                    if (n == 0) break;
                    read += n;
                }
            }
            byte[] salt = new byte[16];
            Buffer.BlockCopy(firstChunk, 0, salt, 0, 16);
            fileSaltB64 = Convert.ToBase64String(salt);
        }
        catch (Exception ex)
        {
            _operationError = $"プレビューエラー: {ex.Message}";
            _previewRef?.SetError(ex.Message);
            item.Downloading = false;
            return;
        }

        var controller = new E2eeStreamController(_previewRef);
        var dotNetRef = DotNetObjectReference.Create(controller);

        try
        {
            await JS.InvokeVoidAsync("cistaMedia.streamE2eeDirect", new
            {
                elementId = MediaPreview.ElementId,
                mimeType,
                apiUrl = Nav.BaseUri.TrimEnd('/'),
                jwtToken = AuthState.Token,
                volumeName = VolumeName,
                fileId = entry.FileId,
                chunkCount = entry.ChunkCount,
                masterKeyHandle = _masterKeyHandle,
                fileSaltBase64 = fileSaltB64,
                dotNetRef,
            });
        }
        catch (JSDisconnectedException) { }
        catch (TaskCanceledException) { }
        catch (Exception)
        {
            // MSE 失敗 → Blob フォールバック
            _previewRef?.SetE2eeLoading(entry.ChunkCount);
            await HandleE2eePreviewBlob(item, entry, mimeType);
        }
        finally
        {
            dotNetRef.Dispose();
        }

        item.Downloading = false;
    }

    /// <summary>E2EE 画像または MSE フォールバック: 全チャンクダウンロード → Blob。</summary>
    private async Task HandleE2eePreviewBlob(E2eeFileViewItem item, E2eeFileEntry entry, string mimeType)
    {
        _previewRef?.SetE2eeLoading(entry.ChunkCount);

        try
        {
            string? fileSaltB64 = null;
            var decryptedChunks = new List<string>();

            for (int i = 0; i < entry.ChunkCount; i++)
            {
                var (chunkStream, chunkLen) = await E2eeFileSvc.DownloadChunkAsync(VolumeName, entry.FileId, i);
                byte[] encData = new byte[chunkLen];
                using (chunkStream)
                {
                    int read = 0;
                    while (read < chunkLen)
                    {
                        int n = await chunkStream.ReadAsync(encData, read, (int)chunkLen - read);
                        if (n == 0) break;
                        read += n;
                    }
                }

                if (i == 0 && fileSaltB64 is null)
                {
                    byte[] salt = new byte[16];
                    Buffer.BlockCopy(encData, 0, salt, 0, 16);
                    fileSaltB64 = Convert.ToBase64String(salt);
                }

                string encB64 = Convert.ToBase64String(encData);
                byte[] plainBytes = await E2ee.DecryptChunk(encB64, _masterKeyHandle!, i, fileSaltB64 ?? "");
                decryptedChunks.Add(Convert.ToBase64String(plainBytes));

                _previewRef?.UpdateProgress(i + 1);
            }

            string blobUrl = await JS.InvokeAsync<string>("cistaCreateMediaBlobUrl", decryptedChunks, mimeType);
            _previewStreamUrl = blobUrl;
            _previewRef?.SetE2eeBlobUrl(blobUrl);
        }
        catch (Exception ex)
        {
            _operationError = $"プレビューエラー: {ex.Message}";
            _previewRef?.SetError(ex.Message);
        }
    }

    private async Task ClosePreview()
    {
        await RevokePreviewBlobUrl();
        _previewVisible = false;
        _previewStreamUrl = null;
    }

    private async Task RevokePreviewBlobUrl()
    {
        if (_previewStreamUrl is not null && _previewStreamUrl.StartsWith("blob:", StringComparison.Ordinal))
        {
            try { await JS.InvokeVoidAsync("cistaMedia.revokeBlobUrl", _previewStreamUrl); }
            catch { /* 既に revoke 済みの場合は無視 */ }
        }
    }

    // ---- E2EE ロック解除 ----

    private async Task HandleE2eeUnlock()
    {
        _e2eeUnlocking = true; _e2eeError = null;
        string? kekHandle = null;
        try
        {
            var (_, header) = VolumeSvc.GetMounted(VolumeName);
            var userKey = header.UserKeys.GetValueOrDefault(CurrentUsername);
            if (userKey is null)
            {
                _e2eeError = "このユーザーの鍵情報が見つかりません。";
                return;
            }

            string saltB64 = Convert.ToBase64String(userKey.Kdf.Salt);
            kekHandle = await E2ee.DeriveKek(_e2eePassword, saltB64, userKey.Kdf.Iterations);
            string nonceB64 = Convert.ToBase64String(userKey.WrappedMasterKey.Nonce);
            string ctB64 = Convert.ToBase64String(userKey.WrappedMasterKey.Ciphertext);
            string tagB64 = Convert.ToBase64String(userKey.WrappedMasterKey.Tag);

            _masterKeyHandle = await E2ee.UnwrapMasterKey(nonceB64, ctB64, tagB64, kekHandle);
            // アンラップ成功後に KEK をクリアし、変数を null にして finally での再試行を防ぐ
            await E2ee.ClearKey(kekHandle);
            kekHandle = null;

            _e2eeUnlocked = true;
            _e2eePassword = "";
            await RefreshE2eeList();
        }
        catch (Exception ex)
        {
            _e2eeError = $"ロック解除失敗: {ex.Message}";
            // 失敗時はマスターキーハンドルも必ず破棄
            if (_masterKeyHandle is not null)
            {
                try { await E2ee.ClearKey(_masterKeyHandle); } catch { /* 握りつぶし */ }
                _masterKeyHandle = null;
            }
        }
        finally
        {
            // 異常系で残った KEK ハンドルを必ずクリア（鍵残留によるエクスポート攻撃を防ぐ）
            if (kekHandle is not null)
            {
                try { await E2ee.ClearKey(kekHandle); } catch { /* 握りつぶし */ }
            }
            _e2eeUnlocking = false;
        }
    }

    // ---- E2EE ファイル一覧 ----

    private async Task RefreshE2eeList()
    {
        try
        {
            var response = await E2eeFileSvc.ListFilesAsync(VolumeName);
            _e2eeFiles = [];
            foreach (var entry in response.Files)
            {
                string plainName;
                try { plainName = await E2ee.DecryptFilename(entry.EncryptedName, _masterKeyHandle!); }
                catch { plainName = $"<{entry.FileId[..8]}...>"; }
                _e2eeFiles.Add(new() { Entry = entry, PlainName = plainName });
            }
        }
        catch { _e2eeFiles = []; }
    }

    // ---- E2EE アップロード ----

    private async Task HandleUpload(InputFileChangeEventArgs e)
    {
        _uploadError = null;
        _operationError = null;
        try
        {
            if (_isE2ee && _e2eeUnlocked)
            {
                await HandleE2eeUpload(e);
            }
            else
            {
                foreach (var file in e.GetMultipleFiles(10))
                {
                    await using var stream = file.OpenReadStream(maxAllowedSize: 10L * 1024 * 1024 * 1024);
                    await FileSvc.UploadAsync(VolumeName, file.Name, stream, file.Size);
                }
                await RefreshList();
            }
        }
        catch (Exception ex)
        {
            _uploadError = $"アップロードエラー: {ex.Message}";
        }
    }

    private async Task HandleE2eeUpload(InputFileChangeEventArgs e)
    {
        const int chunkSize = 1048576;

        foreach (var file in e.GetMultipleFiles(10))
        {
            string encName = await E2ee.EncryptFilename(file.Name, _masterKeyHandle!);
            string fileSaltB64 = await E2ee.GenerateFileSalt();

            await using var stream = file.OpenReadStream(maxAllowedSize: 10L * 1024 * 1024 * 1024);
            long totalSize = file.Size;
            int totalChunks = (int)((totalSize + chunkSize - 1) / chunkSize);
            if (totalChunks == 0) totalChunks = 1;

            // E2eeFileService.ComputeEncryptedLength で一元管理された計算式を使う（salt + chunk ごとの tag）
            long estimatedLength = E2eeComputeEncryptedLength(totalSize, chunkSize);
            var entry = await E2eeFileSvc.CreateFileAsync(VolumeName, new E2eeCreateFileRequest(encName, estimatedLength, totalChunks), CurrentUsername);

            long bytesRemaining = totalSize;
            for (int i = 0; i < totalChunks; i++)
            {
                int readLen = (int)Math.Min(chunkSize, bytesRemaining);
                byte[] buffer = new byte[readLen];
                int read = 0;
                while (read < readLen)
                {
                    int n = await stream.ReadAsync(buffer, read, readLen - read);
                    if (n == 0) break;
                    read += n;
                }
                if (read < buffer.Length) buffer = buffer[..read];

                string encB64 = await E2ee.EncryptChunk(buffer, _masterKeyHandle!, i, fileSaltB64, isFirstChunk: i == 0);
                byte[] encBytes = Convert.FromBase64String(encB64);

                using var ms = new MemoryStream(encBytes);
                await E2eeFileSvc.UploadChunkAsync(VolumeName, entry.FileId, i, ms, encBytes.Length);
                bytesRemaining -= read;
            }

            long actualLength = 16 + (totalChunks > 1 ? ((long)(totalChunks - 1) * (chunkSize + 16)) : 0) + (totalSize - (totalChunks > 1 ? (long)(totalChunks - 1) * chunkSize : 0)) + 16;
            await E2eeFileSvc.FinalizeFileAsync(VolumeName, entry.FileId, new E2eeFinalizeFileRequest(actualLength));
        }

        await RefreshE2eeList();
    }

    // ---- E2EE ダウンロード ----

    private async Task HandleE2eeDownload(E2eeFileViewItem item)
    {
        // ファイルサイズ推定: E2eeFileEntry.EncryptedLength は暗号文 + タグの合計バイト数なので
        // そのままサイズしきい値の比較に使える。ChunkCount × 1MB の近似（旧実装）は
        // 実際の ChunkSize (64 KiB〜16 MiB) と乖離するため廃止。
        long estimatedSize = item.Entry.EncryptedLength;
        const int LargeFileThreshold = 50 * 1024 * 1024; // 50MB

        if (estimatedSize > LargeFileThreshold)
        {
            _operationError = $"ファイルサイズが大きいためブラウザでのダウンロードが制限されています（推定{FormatSize(estimatedSize)}）。Dokanクライアントを使用してください。";
            return;
        }

        item.Downloading = true;
        try
        {
            var entry = item.Entry;
            var decryptedChunks = new List<byte[]>(item.Entry.ChunkCount);
            string? fileSaltB64 = null;

            for (int i = 0; i < entry.ChunkCount; i++)
            {
                var (chunkStream, chunkLen) = await E2eeFileSvc.DownloadChunkAsync(VolumeName, entry.FileId, i);
                byte[] encData = null!;
                using (chunkStream)
                {
                    encData = new byte[chunkLen];
                    int read = 0;
                    while (read < chunkLen)
                    {
                        int n = await chunkStream.ReadAsync(encData, read, (int)chunkLen - read);
                        if (n == 0) break;
                        read += n;
                    }
                }

                if (i == 0 && fileSaltB64 is null)
                {
                    byte[] salt = new byte[16];
                    Buffer.BlockCopy(encData, 0, salt, 0, 16);
                    fileSaltB64 = Convert.ToBase64String(salt);
                }

                string encB64 = Convert.ToBase64String(encData);
                // encData はもう不要なので GC に解放を促す
                Array.Clear(encData, 0, encData.Length);

                byte[] plainBytes = await E2ee.DecryptChunk(encB64, _masterKeyHandle!, i, fileSaltB64 ?? "");
                decryptedChunks.Add(plainBytes);
            }

            // すべてのチャンクを結合して一度だけBase64化
            int totalLength = 0;
            foreach (var chunk in decryptedChunks)
                totalLength += chunk.Length;

            byte[] combined = new byte[totalLength];
            int offset = 0;
            foreach (var chunk in decryptedChunks)
            {
                Buffer.BlockCopy(chunk, 0, combined, offset, chunk.Length);
                offset += chunk.Length;
                // チャンクを解放してメモリを節約
                Array.Clear(chunk, 0, chunk.Length);
            }

            var base64 = Convert.ToBase64String(combined);
            await JS.InvokeVoidAsync("cistaDownload", item.PlainName, base64, "application/octet-stream");
        }
        catch (Exception ex)
        {
            _operationError = $"ダウンロードエラー: {ex.Message}";
        }
        item.Downloading = false;
    }

    private async Task HandleE2eeDelete(string fileId)
    {
        try
        {
            await E2eeFileSvc.DeleteFileAsync(VolumeName, fileId);
            await RefreshE2eeList();
        }
        catch (FileServiceException ex)
        {
            _operationError = ex.Message;
        }
    }

    // ---- 通常ボリューム ----

    private async Task HandleDownload(string fileName)
    {
        try
        {
            var baseUri = Nav.BaseUri.TrimEnd('/');
            var streamToken = StreamingTokenSvc.Issue(CurrentUsername, VolumeName, fileName);
            var streamUrl = $"{baseUri}/api/v1/stream/{Uri.EscapeDataString(VolumeName)}/{Uri.EscapeDataString(fileName)}?token={streamToken}";
            Nav.NavigateTo(streamUrl, forceLoad: true);
        }
        catch (Exception ex)
        {
            _operationError = $"ダウンロードエラー: {ex.Message}";
        }
    }

    private async Task HandleDelete(string fileName)
    {
        try
        {
            await FileSvc.DeleteAsync(VolumeName, fileName);
            await RefreshList();
        }
        catch (FileServiceException ex)
        {
            _operationError = ex.Message;
        }
    }

    private static string FormatSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        < 1024 * 1024 * 1024 => $"{bytes / (1024.0 * 1024):F1} MB",
        _ => $"{bytes / (1024.0 * 1024 * 1024):F2} GB",
    };

    /// <summary>E2EE 暗号化後のサイズを E2eeFileService.ComputeEncryptedLength に委譲（計算式の一元管理）。</summary>
    private static long E2eeComputeEncryptedLength(long plainSize, int chunkSize)
        => E2eeFileService.ComputeEncryptedLength(plainSize, chunkSize);

    private class E2eeFileViewItem
    {
        public E2eeFileEntry Entry { get; set; } = null!;
        public string PlainName { get; set; } = "";
        public bool Downloading { get; set; }
    }

    public async ValueTask DisposeAsync()
    {
        await RevokePreviewBlobUrl();
    }

    private void OnAuthStateChanged() => StateHasChanged();

    public void Dispose() => AuthState.Unsubscribe(OnAuthStateChanged);

    /// <summary>MSE ストリーミングの進捗コールバック用。JS から [JSInvokable] で呼ばれる。</summary>
    private sealed class E2eeStreamController(MediaPreview? preview)
    {
        [JSInvokable]
        public void OnProgress(int loaded) => preview?.UpdateProgress(loaded);
    }
}
