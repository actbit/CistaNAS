@page "/volumes"
@using CistaNAS.Web.Components.Auth
@using CistaNAS.Web.Models
@using CistaNAS.Web.Services
@using CistaNAS.Web.Volume
@inject AuthenticationStateService AuthState
@inject VolumeService VolumeSvc
@inject GroupStore GroupSvc
@inject E2eeInterop E2ee
@inject NavigationManager Nav

<PageTitle>ボリューム - CistaNAS</PageTitle>

@if (!AuthState.IsLoggedIn)
{
    <NavigateToLogin />
}
else
{
    <h1>ボリューム管理</h1>

    <div class="card mb-4">
        <div class="card-header">ボリューム作成</div>
        <div class="card-body">
            <EditForm Model="_createModel" OnValidSubmit="HandleCreate" FormName="CreateVolumeForm">
                <div class="mb-3">
                    <label class="form-label">名前</label>
                    <InputText @bind-Value="_createModel.Name" class="form-control" />
                </div>
                <div class="mb-3 form-check">
                    <InputCheckbox @bind-Value="_createModel.Encrypted" class="form-check-input" id="chkEncrypted" />
                    <label class="form-check-label" for="chkEncrypted">暗号化する</label>
                </div>
                @if (_createModel.Encrypted)
                {
                    <div class="mb-3">
                        <label class="form-label">暗号化方式</label>
                        <div class="form-check">
                            <input type="radio" class="form-check-input" name="encMode" id="encServer"
                                   checked="@(_createModel.EncryptionMode == "server")"
                                   @onchange="@(() => _createModel.EncryptionMode = "server")" />
                            <label class="form-check-label" for="encServer">
                                サーバー暗号化（AES-XTS）
                            </label>
                        </div>
                        <div class="form-check">
                            <input type="radio" class="form-check-input" name="encMode" id="encE2ee"
                                   checked="@(_createModel.EncryptionMode == "e2ee")"
                                   @onchange="@(() => _createModel.EncryptionMode = "e2ee")" />
                            <label class="form-check-label" for="encE2ee">
                                E2EE（エンドツーエンド暗号化）
                            </label>
                        </div>
                    </div>
                }
                @if (_createModel.Encrypted)
                {
                    <div class="mb-3">
                        <label class="form-label">パスワード（確認用）</label>
                        <InputText type="password" @bind-Value="_createModel.Password" class="form-control" />
                    </div>
                }
                @if (_createModel.Encrypted && _createModel.EncryptionMode == "e2ee")
                {
                    <div class="alert alert-info">
                        <strong>E2EE ボリューム</strong>: マスターキーはブラウザ内で生成され、サーバーには送信されません。
                        パスワードを紛失するとデータを復旧できません。
                    </div>
                }
                else if (_createModel.Encrypted)
                {
                    <div class="alert alert-info">
                        ユーザー <strong>@CurrentUsername</strong> の認証情報でマスター鍵を暗号化します。
                    </div>
                }
                <button type="submit" class="btn btn-success" disabled="@_isCreating">
                    @(_isCreating ? "作成中..." : "作成")
                </button>
            </EditForm>
            @if (_createError is not null)
            {
                <div class="alert alert-danger mt-2">@_createError</div>
            }
        </div>
    </div>

    <h2>ボリューム一覧</h2>
    @if (_volumes.Count == 0)
    {
        <p>ボリュームがありません。</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>名前</th>
                    <th>暗号化</th>
                    <th>所有ユーザー</th>
                    <th>共有</th>
                    <th>状態</th>
                    <th>作成日</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in _volumes)
                {
                    <tr>
                        <td>
                            @v.Name
                            @if (v.IsHome)
                            {
                                <span class="badge bg-info ms-1">Home</span>
                            }
                        </td>
                        <td>
                            @if (v.EncryptionMode == "e2ee")
                            {
                                <span class="badge bg-info">E2EE</span>
                            }
                            else if (v.Encrypted)
                            {
                                <span class="badge bg-primary">サーバー</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">なし</span>
                            }
                        </td>
                        <td>@v.OwnerUser</td>
                        <td>@(v.AuthorizedUsers.Count > 1 ? $"{v.AuthorizedUsers.Count} ユーザー" : "-")</td>
                        <td>
                            @if (v.IsMounted)
                            {
                                <span class="badge bg-success">マウント済み</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">未マウント</span>
                            }
                        </td>
                        <td>@v.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @if (v.IsMounted)
                            {
                                <button class="btn btn-sm btn-outline-danger me-1" @onclick="() => HandleLock(v.Name)">ロック</button>
                                <a href="/files/@v.Name" class="btn btn-sm btn-outline-primary me-1">ファイル</a>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ShowMountDialog(v.Name, v.Encrypted, v.EncryptionMode)">マウント</button>
                            }
                            @if (v.OwnerUser == CurrentUsername && v.Encrypted && !v.IsHome)
                            {
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => ShowShareDialog(v.Name)">共有</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (_mountTarget is not null)
    {
        <div class="modal d-block" tabindex="-1" style="background-color:rgba(0,0,0,0.5)">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">マウント: @_mountTarget</h5>
                        <button type="button" class="btn-close" @onclick="CloseMountDialog"></button>
                    </div>
                    <div class="modal-body">
                        @if (_mountIsE2ee)
                        {
                            <div class="alert alert-warning">
                                E2EE ボリュームです。パスワードを入力するとブラウザ内でマスターキーが導出されます。
                            </div>
                            <div class="mb-3">
                                <label class="form-label">パスワード</label>
                                <input type="password" class="form-control" @bind="_mountPassword" />
                            </div>
                        }
                        else if (_mountNeedsPassword)
                        {
                            <div class="mb-3">
                                <label class="form-label">パスワード</label>
                                <input type="password" class="form-control" @bind="_mountPassword" />
                            </div>
                        }
                        else
                        {
                            <p>非暗号化ボリュームです。</p>
                        }
                        @if (_mountError is not null)
                        {
                            <div class="alert alert-danger">@_mountError</div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseMountDialog">キャンセル</button>
                        <button type="button" class="btn btn-primary" disabled="@_isMounting" @onclick="HandleMount">
                            @(_isMounting ? "マウント中..." : "マウント")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_shareTarget is not null)
    {
        <div class="modal d-block" tabindex="-1" style="background-color:rgba(0,0,0,0.5)">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">共有: @_shareTarget</h5>
                        <button type="button" class="btn-close" @onclick="CloseShareDialog"></button>
                    </div>
                    <div class="modal-body">
                        <h6>アクセス権のあるユーザー</h6>
                        <ul class="list-group mb-3">
                            @foreach (var u in _shareUsers)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    @u
                                    @if (u != CurrentUsername)
                                    {
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => HandleRevoke(_shareTarget, u)">削除</button>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary">オーナー</span>
                                    }
                                </li>
                            }
                        </ul>
                        <hr />
                        <h6>ユーザーを追加</h6>
                        <div class="mb-2">
                            <input class="form-control mb-2" placeholder="ユーザー名" @bind="_grantUsername" />
                            <input type="password" class="form-control mb-2" placeholder="対象ユーザーのパスワード" @bind="_grantPassword" />
                            <input type="password" class="form-control mb-2" placeholder="自分のパスワード（確認）" @bind="_grantGranterPassword" />
                        </div>
                        @if (_shareError is not null)
                        {
                            <div class="alert alert-danger">@_shareError</div>
                        }

                        @if (!_shareIsE2ee)
                        {
                            <hr />
                            <h6>グループアクセス</h6>
                            @if (_shareGroups.Count > 0)
                            {
                                <ul class="list-group mb-2">
                                    @foreach (var gn in _shareGroups)
                                    {
                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                            @gn
                                            <button class="btn btn-sm btn-outline-danger"
                                                    @onclick="() => HandleRevokeGroup(_shareTarget!, gn)">削除</button>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <p class="text-muted small">グループに共有されていません。</p>
                            }
                            <div class="row g-2 align-items-end">
                                <div class="col">
                                    <select class="form-select form-select-sm" @bind="_grantGroupName">
                                        <option value="">グループを選択</option>
                                        @foreach (var g in _availableGroups)
                                        {
                                            <option value="@g.GroupName">@g.GroupName</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-auto">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="HandleGrantGroup">追加</button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info mt-2">E2EE ボリュームはグループ共有に対応していません。</div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseShareDialog">閉じる</button>
                        <button type="button" class="btn btn-primary" @onclick="HandleGrant">ユーザー追加</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    private List<VolumeInfo> _volumes = [];
    private CreateModel _createModel = new() { Encrypted = true };
    private bool _isCreating;
    private string? _createError;

    private string? _mountTarget;
    private bool _mountNeedsPassword;
    private bool _mountIsE2ee;
    private bool _isMounting;
    private string _mountPassword = "";
    private string? _mountError;

    private string? _shareTarget;
    private IReadOnlyList<string> _shareUsers = [];
    private bool _shareIsE2ee;
    private IReadOnlyList<string> _shareGroups = [];
    private IReadOnlyList<GroupAccount> _availableGroups = [];
    private string _grantGroupName = "";
    private string _grantUsername = "";
    private string _grantPassword = "";
    private string _grantGranterPassword = "";
    private string? _shareError;

    private sealed class CreateModel
    {
        public string Name { get; set; } = "";
        public string Password { get; set; } = "";
        public bool Encrypted { get; set; } = true;
        public string EncryptionMode { get; set; } = "server";
    }

    private string CurrentUsername => AuthState.User?.Identity?.Name ?? "";

    protected override void OnInitialized() => RefreshList();
    private void RefreshList() => _volumes = VolumeSvc.ListForUser(CurrentUsername).ToList();

    private async Task HandleCreate()
    {
        _isCreating = true; _createError = null;
        try
        {
            if (_createModel.Encrypted && _createModel.EncryptionMode == "e2ee")
            {
                await HandleCreateE2ee();
            }
            else
            {
                VolumeSvc.Create(_createModel.Name, CurrentUsername, _createModel.Password, _createModel.Encrypted);
            }
            _createModel = new() { Encrypted = true };
            RefreshList();
        }
        catch (Exception ex) { _createError = ex.Message; }
        _isCreating = false;
    }

    private async Task HandleCreateE2ee()
    {
        // クライアント側で KEK 導出 → マスターキー生成 → ラップ
        byte[] salt = System.Security.Cryptography.RandomNumberGenerator.GetBytes(16);
        string saltB64 = Convert.ToBase64String(salt);
        string kekHandle = await E2ee.DeriveKek(_createModel.Password, saltB64, 310_000);
        string mkHandle = await E2ee.GenerateMasterKey();
        var (nonceB64, ctB64, tagB64) = await E2ee.WrapMasterKey(mkHandle, kekHandle);
        await E2ee.ClearKey(kekHandle);
        await E2ee.ClearKey(mkHandle);

        var wrappedKey = new VolumeHeader.UserWrappedKey
        {
            Kdf = new() { Algorithm = "pbkdf2-sha256", Iterations = 310_000, Salt = salt },
            WrappedMasterKey = new()
            {
                Algorithm = "aes-256-gcm",
                Nonce = Convert.FromBase64String(nonceB64),
                Ciphertext = Convert.FromBase64String(ctB64),
                Tag = Convert.FromBase64String(tagB64),
            },
        };

        VolumeSvc.CreateE2ee(_createModel.Name, CurrentUsername, wrappedKey);
    }

    private void ShowMountDialog(string name, bool encrypted, string encryptionMode)
    {
        _mountTarget = name;
        _mountNeedsPassword = encrypted;
        _mountIsE2ee = encryptionMode == "e2ee";
        _mountPassword = ""; _mountError = null; _isMounting = false;
    }
    private void CloseMountDialog() { _mountTarget = null; _mountError = null; }

    private async Task HandleMount()
    {
        _isMounting = true; _mountError = null;
        try
        {
            if (_mountIsE2ee)
            {
                // E2EE: サーバー側でマウント（アクセス権チェックのみ）
                VolumeSvc.MountE2ee(_mountTarget!, CurrentUsername);
            }
            else
            {
                VolumeSvc.Mount(_mountTarget!, CurrentUsername, _mountNeedsPassword ? _mountPassword : null);
            }
            CloseMountDialog(); RefreshList();
        }
        catch (VolumeException ex) { _mountError = ex.Message; }
        _isMounting = false;
    }

    private void HandleLock(string name)
    {
        try { VolumeSvc.Lock(name); RefreshList(); } catch { }
    }

    private void ShowShareDialog(string name)
    {
        var vol = _volumes.FirstOrDefault(v => v.Name == name);
        if (vol is null) return;
        _shareTarget = name; _shareUsers = vol.AuthorizedUsers;
        _shareIsE2ee = vol.EncryptionMode == "e2ee";
        _shareGroups = vol.AuthorizedGroups;
        _availableGroups = GroupSvc.ListGroups();
        _grantGroupName = "";
        _grantUsername = ""; _grantPassword = ""; _grantGranterPassword = ""; _shareError = null;
    }
    private void CloseShareDialog() { _shareTarget = null; _shareError = null; }

    private void HandleGrant()
    {
        try
        {
            VolumeSvc.GrantAccess(_shareTarget!, CurrentUsername, _grantGranterPassword, _grantUsername, _grantPassword);
            RefreshList();
            var vol = _volumes.FirstOrDefault(v => v.Name == _shareTarget);
            if (vol is not null) _shareUsers = vol.AuthorizedUsers;
            _grantUsername = ""; _grantPassword = ""; _grantGranterPassword = ""; _shareError = null;
        }
        catch (VolumeException ex) { _shareError = ex.Message; }
    }

    private void HandleRevoke(string volumeName, string targetUser)
    {
        try
        {
            VolumeSvc.RevokeAccess(volumeName, CurrentUsername, targetUser);
            RefreshList();
            var vol = _volumes.FirstOrDefault(v => v.Name == _shareTarget);
            if (vol is not null) _shareUsers = vol.AuthorizedUsers;
        }
        catch (VolumeException ex) { _shareError = ex.Message; }
    }

    private void HandleGrantGroup()
    {
        if (string.IsNullOrEmpty(_grantGroupName)) return;
        try
        {
            VolumeSvc.GrantGroupAccess(_shareTarget!, CurrentUsername, _grantGroupName);
            RefreshList();
            var vol = _volumes.FirstOrDefault(v => v.Name == _shareTarget);
            if (vol is not null) _shareGroups = vol.AuthorizedGroups;
            _grantGroupName = ""; _shareError = null;
        }
        catch (VolumeException ex) { _shareError = ex.Message; }
    }

    private void HandleRevokeGroup(string volumeName, string groupName)
    {
        try
        {
            VolumeSvc.RevokeGroupAccess(volumeName, CurrentUsername, groupName);
            RefreshList();
            var vol = _volumes.FirstOrDefault(v => v.Name == _shareTarget);
            if (vol is not null) _shareGroups = vol.AuthorizedGroups;
        }
        catch (VolumeException ex) { _shareError = ex.Message; }
    }
}
