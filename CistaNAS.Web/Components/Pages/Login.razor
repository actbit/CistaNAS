@page "/login"
@using CistaNAS.Web.Components.Auth
@implements IDisposable
@inject AuthenticationStateService AuthState
@inject NavigationManager Nav

<PageTitle>ログイン - CistaNAS</PageTitle>

<h1>ログイン</h1>

@if (ErrorMessage is not null)
{
    <div class="alert alert-danger">@ErrorMessage</div>
}

<div class="form-narrow">
<EditForm Model="_model" OnValidSubmit="HandleLogin" FormName="LoginForm">
    <DataAnnotationsValidator />
    <div class="mb-3">
        <label class="form-label" for="username">ユーザ名</label>
        <InputText @bind-Value="_model.Username" class="form-control" id="username" />
    </div>
    <div class="mb-3">
        <label class="form-label" for="password">パスワード</label>
        <InputText type="password" @bind-Value="_model.Password" class="form-control" id="password" />
    </div>
    <button type="submit" class="btn btn-primary" disabled="@IsLoading">
        @(IsLoading ? "ログイン中..." : "ログイン")
    </button>
</EditForm>
</div>

@code {
    private LoginModel _model = new();
    private bool IsLoading;
    private string? ErrorMessage;

    private sealed class LoginModel
    {
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
    }

    protected override void OnInitialized()
    {
        AuthState.Subscribe(OnAuthStateChanged);
    }

    private async Task HandleLogin()
    {
        IsLoading = true;
        ErrorMessage = null;

        try
        {
            bool ok = await AuthState.LoginAsync(_model.Username, _model.Password);
            if (ok)
            {
                Nav.NavigateTo("/volumes", forceLoad: false);
            }
            else
            {
                ErrorMessage = "ユーザ名またはパスワードが正しくありません。";
            }
        }
        catch
        {
            ErrorMessage = "ログイン中にエラーが発生しました。";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void OnAuthStateChanged() => StateHasChanged();

    public void Dispose() => AuthState.Unsubscribe(OnAuthStateChanged);
}
