{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "localhost",
  "CistaNas": {
    "DataRoot": "data",
    "Storage": {
      "Provider": "local"
    },
    "Jwt": {
      "Issuer": "CistaNAS",
      "Audience": "CistaNAS",
      "SigningKey": null,
      "AccessTokenMinutes": 60
    },
    "Auth": {
      "DefaultAdminUser": "admin",
      "DefaultAdminPassword": null,
      "Pbkdf2Iterations": 600000
    },
    "Volume": {
      "SectorSize": 4096,
      "KdfIterations": 600000
    }
  }
}
